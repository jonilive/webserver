<?xml version="1.0"?>
<Container version="2">
  <n>Webserver</n>
  <Repository>ghcr.io/jonilive/webserver:latest</Repository>
  <Registry>https://github.com/jonilive/webserver</Registry>
  <Network>bridge</Network>
  <MyIP></MyIP>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/jonilive/webserver/issues</Support>
  <Project>https://github.com/jonilive/webserver</Project>
  <Overview>
    Webserver running the latest alpine, apache and php
    
    Features:
    - Apache 2.4 web server with PHP 8.5 integration
    - PHP 8.5 with extensive extensions (GD, MySQLi, Redis, SOAP, XML, ZIP, etc.)
    - Cron daemon for scheduled tasks
    - Configurable via mounted volumes - edit configs without rebuilding
    - Development tools included: Git, Python 3, Node.js, npm, htop
    - Lightweight Alpine Linux base
  </Overview>
  <Category>Network:Web</Category>
  <WebUI>http://[IP]:[PORT:80]</WebUI>
  <TemplateURL></TemplateURL>
  <Icon>https://raw.githubusercontent.com/jonilive/webserver/master/logo.png</Icon>
  <ExtraParams></ExtraParams>
  <PostArgs></PostArgs>
  <CPUset></CPUset>
  <DateInstalled>1656835200</DateInstalled>
  <DonateText></DonateText>
  <DonateLink></DonateLink>
  <Requires></Requires>
  <Config Name="HTTP Port" Target="80" Default="80" Mode="tcp" Description="HTTP Port" Type="Port" Display="always" Required="true" Mask="false">80</Config>
  <Config Name="Config folder" Target="/var/config" Default="/mnt/user/appdata/webserver/config" Mode="rw" Description="Config folder" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/webserver/config</Config>
  <Config Name="Log folder" Target="/var/log" Default="/mnt/user/appdata/webserver/log" Mode="rw" Description="Log folder" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/webserver/log</Config>
  <Config Name="WWW folder" Target="/www" Default="/mnt/user/appdata/webserver/www" Mode="rw" Description="WWW folder" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/webserver/www</Config>
</Container>
